<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Book Notes - Organize Your Reading</title>
    <link rel="stylesheet" href="/styles/style.css">
</head>
<body>
    <!-- Include header template -->
    <%- include('header') %>

    <!-- Main Content Container -->
    <main class="container">
        <!-- Page Title Section -->
        <section class="hero">
            <h2>Welcome to Your Book Collection</h2>
            <p>Track the books you've read, rate them, and capture your thoughts.</p>
        </section>

        <!-- Sort Controls -->
        <section class="controls">
            <div class="sort-container">
                <label for="sortBy" class="sort-label">Sort by:</label>
                <select id="sortBy" class="sort-select" onchange="changeSortBy(this.value)">
                    <option value="date_read" <%= currentSort === 'date_read' ? 'selected' : '' %>>Date Read (Newest)</option>
                    <option value="rating" <%= currentSort === 'rating' ? 'selected' : '' %>>Rating (Highest)</option>
                    <option value="title" <%= currentSort === 'title' ? 'selected' : '' %>>Title (A-Z)</option>
                </select>
            </div>
            <div class="book-count">
                <span class="count-badge"><%= books.length %></span>
                <span class="count-label">book<%= books.length !== 1 ? 's' : '' %> in collection</span>
            </div>
        </section>

        <!-- Books Display Section -->
        <% if (books.length === 0) { %>
            <!-- Empty State -->
            <section class="empty-state">
                <div class="empty-icon">📚</div>
                <h3>No books yet!</h3>
                <p>Start building your book collection by adding your first book.</p>
                <a href="/new" class="btn btn-primary">Add Your First Book</a>
            </section>
        <% } else { %>
            <!-- Books Grid -->
            <section class="books-grid">
                <% books.forEach((book) => { %>
                    <div class="book-card">
                        <!-- Book Cover -->
                        <div class="book-cover">
                            <% if (book.cover_url) { %>
                                <img src="<%= book.cover_url %>" alt="<%= book.title %> cover" class="cover-image">
                            <% } else { %>
                                <div class="no-cover">
                                    <span class="book-icon">📖</span>
                                </div>
                            <% } %>
                        </div>

                        <!-- Book Info -->
                        <div class="book-info">
                            <h3 class="book-title"><%= book.title %></h3>
                            <p class="book-author">by <%= book.author %></p>

                            <!-- Rating -->
                            <div class="rating">
                                <% for (let i = 1; i <= 5; i++) { %>
                                    <span class="star <%= i <= book.rating ? 'filled' : '' %>">★</span>
                                <% } %>
                                <span class="rating-text">(<%= book.rating %>/5)</span>
                            </div>

                            <!-- Date Read -->
                            <% if (book.date_read) { %>
                                <p class="meta-info">
                                    <span class="meta-label">Read:</span>
                                    <%= new Date(book.date_read).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                                </p>
                            <% } %>

                            <!-- ISBN -->
                            <% if (book.isbn) { %>
                                <p class="meta-info">
                                    <span class="meta-label">ISBN:</span>
                                    <%= book.isbn %>
                                </p>
                            <% } %>

                            <!-- Review -->
                            <% if (book.review) { %>
                                <p class="book-review">
                                    <span class="review-label">Review:</span>
                                    <%= book.review %>
                                </p>
                            <% } %>

                            <!-- Action Buttons -->
                            <div class="book-actions">
                                <a href="/edit/<%= book.id %>" class="btn btn-small btn-edit">✏️ Edit</a>
                                <form method="POST" action="/delete/<%= book.id %>" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this book?');">
                                    <button type="submit" class="btn btn-small btn-delete">🗑️ Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </section>
        <% } %>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <p>&copy; 2024 My Book Notes. Keep reading, keep learning! 📚</p>
    </footer>

    <!-- Script for sort functionality -->
    <script>
        function changeSortBy(sortValue) {
            window.location.href = '/?sort=' + sortValue;
        }
    </script>
</body>
</html>
